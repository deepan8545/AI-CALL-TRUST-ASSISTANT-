# === AI Call Trust Assistant — Environment Variables ===

# FastAPI
APP_ENV=development
APP_PORT=8000
APP_VERSION=0.1.0
DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=call_trust
POSTGRES_USER=call_trust_user
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_CALL_EVENTS=call.events
KAFKA_TOPIC_CALL_SCORED=call.scored
KAFKA_TOPIC_CALL_TRANSCRIBED=call.transcribed
KAFKA_TOPIC_CALL_SUMMARIZED=call.summarized
KAFKA_TOPIC_FRAUD_FEEDBACK=fraud.feedback
KAFKA_TOPIC_GRAPH_UPDATES=graph.updates

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_in_production

# ML
USE_ML_SCORER=false
ML_MODEL_PATH=services/ml-risk-service/models/xgboost_v1.json

# LLM Providers
LLM_PROVIDER=mock
CLAUDE_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Vector Search
VECTOR_SEARCH_PROVIDER=pgvector

# Object Storage
S3_BUCKET=call-trust-data
AWS_REGION=us-east-1

# Observability
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
PROMETHEUS_PORT=9090
